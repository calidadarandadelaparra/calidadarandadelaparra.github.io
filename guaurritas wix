<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Guaurritas Desktop Layout Final</title>
<style>
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    width: 100%;
    min-width: 0;
    min-height: 100%;
    overflow-x: clip;
    overflow-y: hidden;
    font-family: Arial, sans-serif;
    background: transparent;
  }
  .viewport {
    --scene-ratio: 1265 / 482;
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    margin: 0 auto;
    aspect-ratio: var(--scene-ratio);
    min-height: clamp(360px, 36vw, 680px);
    overflow: hidden;
    background: transparent;
    isolation: isolate;
  }
  @supports not (aspect-ratio: 1 / 1) {
    .viewport {
      height: clamp(360px, 36vw, 680px);
    }
  }
  #scene {
    position: absolute;
    left: 0;
    top: 0;
    width: 1265px;
    height: 482px;
    transform-origin: top left;
    will-change: transform;
    overflow: visible;
    background: url('data:image/jpeg;base64,') center center / 100% 100% no-repeat;
    box-shadow: none;
  }
  .desktop-frame {
    position: absolute;
    border: 0;
    background: transparent;
    overflow: hidden;
    display: block;
  }
  .desktop-frame:not(.bar-frame) {
    filter: drop-shadow(0 8px 18px rgba(0,0,0,0.15));
  }

  iframe.desktop-frame {
    position: absolute;
    display: block;
    border: 0;
    max-width: none;
    background: transparent;
  }
  @media (max-width: 1439px) {
    .viewport {
      min-height: clamp(380px, 40vw, 720px);
    }
  }
  @media (max-width: 1279px) {
    .viewport {
      min-height: clamp(460px, 52vw, 860px);
    }
  }
  @media (max-width: 1023px) {
    .viewport {
      min-height: clamp(560px, 72vw, 980px);
    }
  }
  @media (max-width: 767px) {
    html, body {
      overflow-x: hidden;
    }
    .viewport {
      min-height: clamp(820px, 175vw, 1180px);
    }
  }



  .desktop-window {
    position: absolute;
    overflow: visible;
    user-select: none;
    touch-action: none;
  }
  .desktop-window.is-dragging,
  .desktop-window.is-resizing {
    will-change: left, top, width, height;
  }
  .desktop-window .window-drag-handle {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: calc(28px * var(--win-scale, 1));
    z-index: 3;
    cursor: move;
    background: transparent;
  }
  .desktop-window .window-resize-handle {
    position: absolute;
    right: -2px;
    bottom: -2px;
    width: 16px;
    height: 16px;
    z-index: 4;
    cursor: nwse-resize;
    background: transparent;
  }
  .desktop-window .window-resize-handle::before {
    content: '';
    position: absolute;
    right: 2px;
    bottom: 2px;
    width: 10px;
    height: 10px;
    border-right: 2px solid rgba(255,255,255,.65);
    border-bottom: 2px solid rgba(255,255,255,.65);
    opacity: .55;
  }
  .desktop-window .desktop-frame {
    left: 0 !important;
    top: 0 !important;
  }
  .desktop-window.is-active {
    filter: drop-shadow(0 8px 14px rgba(0,0,0,.18));
  }
  @media (max-width: 1023px) {
    .desktop-window .window-resize-handle { display: none; }
  }
  @media (max-width: 767px) {
    .desktop-window .window-drag-handle,
    .desktop-window .window-resize-handle { display: none; }
  }

</style>
</head>
<body>
  <div class="viewport">
    <div id="scene">
    </div>
  </div>

<script>
const DOCS64 = {"menu": "", "offer": "", "welcome": "", "color": "", "chat": "", "promo": "", "toolbar": "", "menu_extra": "",
"paint": ""};
const SCENE_W = 1265;
const SCENE_H = 482;
const LAYOUT = [
  { key: "chat", x: 100, y: 18, w: 342, h: 300, z: 20, scale: 0.66 },
  { key: "welcome", x: 417, y: 45, w: 640, h: 228, z: 18, scale: 0.73 },
  { key: "paint", x: 965, y: 35, w: 360, h: 300, z: 22, scale: 0.74 },
  { key: "menu", x: 398, y: 220, w: 300, h: 270, z: 24, scale: 0.58 },
  { key: "offer", x: 678, y: 214, w: 340, h: 360, z: 25, scale: 0.63 },
  { key: "color", x: 992, y: 345, w: 240, h: 198, z: 26, scale: 0.53 }
];

function decodeUtf8Base64(b64) {
  const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
  return new TextDecoder().decode(bytes);
}

function patchDoc(html, key) {
  let output = html;

  if (key === 'welcome') {
    const welcomeFix = `<style>
      html, body {
        min-height: 0 !important;
        height: auto !important;
        margin: 0 !important;
        padding: 0 !important;
        overflow: hidden !important;
        background: transparent !important;
      }
      .window {
        width: 640px !important;
        min-width: 0 !important;
        max-width: 640px !important;
        max-height: none !important;
        resize: none !important;
        overflow: hidden !important;
      }
    </style>`;
    output = output.replace('</head>', welcomeFix + '</head>');
  }

  if (key === 'menu') {
    const menuFix = `<style>
      html, body {
        background: transparent !important;
        width: auto !important;
        height: auto !important;
        min-height: 0 !important;
        overflow: hidden !important;
        display: block !important;
        margin: 0 !important;
        padding: 0 !important;
      }
      .win-box {
        width: 300px !important;
        overflow: hidden !important;
      }
    </style>`;
    output = output.replace('</head>', menuFix + '</head>');
  }

  if (key === 'paint') {
    const paintFix = `<style>
      html, body {
        background: transparent !important;
        width: 360px !important;
        height: auto !important;
        min-height: 0 !important;
        overflow: hidden !important;
        display: block !important;
        margin: 0 !important;
        padding: 0 !important;
      }
      .paint-window {
        margin: 0 !important;
      }
    </style>`;
    output = output.replace('</head>', paintFix + '</head>');
  }

  if (key === 'offer') {
    const offerFix = `<style>
      html, body {
        background: transparent !important;
        width: 340px !important;
        height: auto !important;
        min-height: 0 !important;
        overflow: hidden !important;
        display: block !important;
        margin: 0 !important;
        padding: 0 !important;
      }
      .win-window {
        width: 340px !important;
        height: auto !important;
        min-height: 320px !important;
      }
    </style>`;
    output = output.replace('</head>', offerFix + '</head>');
  }

  if (key === 'chat') {
    const chatFix = `<style>
      html, body {
        background: transparent !important;
        width: 340px !important;
        height: auto !important;
        min-height: 0 !important;
        overflow: hidden !important;
        display: block !important;
        margin: 0 !important;
        padding: 0 !important;
      }
      .msn { width: 340px !important; }
    </style>`;
    output = output.replace('</head>', chatFix + '</head>');
  }

  if (key === 'color') {
    const colorFix = `<style>
      html, body {
        overflow: hidden !important;
        background: transparent !important;
        width: 240px !important;
        height: auto !important;
        min-height: 0 !important;
        display: block !important;
        margin: 0 !important;
        padding: 0 !important;
      }
      .dialog { width: 240px !important; }
    </style>`;
    output = output.replace('</head>', colorFix + '</head>');
  }

  const activateScript = `<script>
    window.addEventListener('pointerdown', function () {
      try {
        if (window.parent && typeof window.parent.__desktopBringToFront === 'function') {
          window.parent.__desktopBringToFront('__WINDOW_KEY__');
        }
      } catch (e) {}
    }, { passive: true });
  <\/script>`;

  if (output.includes('</body>')) {
    output = output.replace('</body>', activateScript.replace(/__WINDOW_KEY__/g, key) + '</body>');
  } else if (output.includes('</html>')) {
    output = output.replace('</html>', activateScript.replace(/__WINDOW_KEY__/g, key) + '</html>');
  } else {
    output += activateScript.replace(/__WINDOW_KEY__/g, key);
  }

  return output;
}

const scene = document.getElementById('scene');
const viewport = document.querySelector('.viewport');
const frameMap = {};
const shellMap = {};
const manualState = {};
let activeZ = 40;
let currentMode = 'desktop';
let activePointer = null;

const BASE_LAYOUT = {
  chat:    { key: 'chat',    x: 100, y: 18,  w: 342, h: 300, z: 20, scale: 0.66 },
  welcome: { key: 'welcome', x: 417, y: 45,  w: 640, h: 228, z: 18, scale: 0.73 },
  paint:   { key: 'paint',   x: 965, y: 35,  w: 360, h: 300, z: 22, scale: 0.74 },
  menu:    { key: 'menu',    x: 398, y: 220, w: 300, h: 270, z: 24, scale: 0.58 },
  offer:   { key: 'offer',   x: 678, y: 214, w: 340, h: 360, z: 25, scale: 0.63 },
  color:   { key: 'color',   x: 992, y: 345, w: 240, h: 198, z: 26, scale: 0.53 }
};

function cloneItem(key, overrides = {}) {
  return { ...BASE_LAYOUT[key], ...overrides };
}

function getResponsiveConfig(width) {
  if (width <= 767) {
    return {
      mode: 'mobile',
      sceneW: 420,
      sceneH: 980,
      items: [
        cloneItem('welcome', { x: 18, y: 22,  scale: 0.58, z: 10 }),
        cloneItem('chat',    { x: 22, y: 182, scale: 0.82, z: 12 }),
        cloneItem('paint',   { x: 90, y: 392, scale: 0.66, z: 14 }),
        cloneItem('offer',   { x: 106, y: 598, scale: 0.72, z: 16 }),
        cloneItem('menu',    { x: 24, y: 784, scale: 0.62, z: 18 }),
        cloneItem('color',   { x: 224, y: 812, scale: 0.70, z: 20 })
      ]
    };
  }

  if (width <= 1023) {
    return {
      mode: 'tablet',
      sceneW: 760,
      sceneH: 760,
      items: [
        cloneItem('chat',    { x: 26,  y: 34,  scale: 0.74 }),
        cloneItem('welcome', { x: 248, y: 52,  scale: 0.72 }),
        cloneItem('paint',   { x: 468, y: 252, scale: 0.72 }),
        cloneItem('menu',    { x: 96,  y: 266, scale: 0.62 }),
        cloneItem('offer',   { x: 242, y: 458, scale: 0.72 }),
        cloneItem('color',   { x: 58,  y: 566, scale: 0.66 })
      ]
    };
  }

  if (width <= 1279) {
    return {
      mode: 'desktop',
      sceneW: 980,
      sceneH: 600,
      items: [
        cloneItem('chat',    { x: 46,  y: 24,  scale: 0.64 }),
        cloneItem('welcome', { x: 282, y: 44,  scale: 0.70 }),
        cloneItem('paint',   { x: 706, y: 30,  scale: 0.68 }),
        cloneItem('menu',    { x: 252, y: 238, scale: 0.58 }),
        cloneItem('offer',   { x: 480, y: 226, scale: 0.62 }),
        cloneItem('color',   { x: 776, y: 330, scale: 0.56 })
      ]
    };
  }

  if (width <= 1439) {
    return {
      mode: 'desktop',
      sceneW: 1140,
      sceneH: 500,
      items: [
        cloneItem('chat',    { x: 70,  y: 18,  scale: 0.65 }),
        cloneItem('welcome', { x: 350, y: 40,  scale: 0.72 }),
        cloneItem('paint',   { x: 855, y: 28,  scale: 0.71 }),
        cloneItem('menu',    { x: 334, y: 232, scale: 0.58 }),
        cloneItem('offer',   { x: 566, y: 222, scale: 0.63 }),
        cloneItem('color',   { x: 880, y: 336, scale: 0.53 })
      ]
    };
  }

  return {
    mode: 'desktop',
    sceneW: 1265,
    sceneH: 482,
    items: Object.values(BASE_LAYOUT)
  };
}

function getNaturalFrameSize(frame, item) {
  try {
    const doc = frame.contentDocument;
    if (!doc) return { w: item.w, h: item.h };
    const html = doc.documentElement;
    const body = doc.body;
    const w = Math.max(
      item.w || 0,
      html ? html.scrollWidth : 0,
      html ? html.offsetWidth : 0,
      body ? body.scrollWidth : 0,
      body ? body.offsetWidth : 0
    );
    const h = Math.max(
      item.h || 0,
      html ? html.scrollHeight : 0,
      html ? html.offsetHeight : 0,
      body ? body.scrollHeight : 0,
      body ? body.offsetHeight : 0
    );
    return { w: w + 2, h: h + 4 };
  } catch (e) {
    return { w: item.w, h: item.h };
  }
}

function scaleScene(sceneW, sceneH) {
  const vw = viewport.clientWidth || window.innerWidth;
  const vh = viewport.clientHeight || Math.round(vw * (sceneH / sceneW));
  const scale = Math.min(vw / sceneW, vh / sceneH);
  const scaledW = sceneW * scale;
  const scaledH = sceneH * scale;
  scene.style.transform = `scale(${scale})`;
  scene.style.left = `${Math.max(0, (vw - scaledW) / 2)}px`;
  scene.style.top = `${Math.max(0, (vh - scaledH) / 2)}px`;
}

function getModeKey(config) {
  return config.mode === 'mobile' ? 'mobile' : (config.mode === 'tablet' ? 'tablet' : 'desktop');
}

function getManual(key, modeKey) {
  return manualState[modeKey] && manualState[modeKey][key] ? manualState[modeKey][key] : null;
}

function setManual(key, modeKey, data) {
  if (!manualState[modeKey]) manualState[modeKey] = {};
  manualState[modeKey][key] = { ...(manualState[modeKey][key] || {}), ...data };
}

function clearManual(modeKey) {
  if (manualState[modeKey]) manualState[modeKey] = {};
}

function updateShellFromItem(item, config, useManual = true) {
  const shell = shellMap[item.key];
  const frame = frameMap[item.key];
  if (!shell || !frame) return;

  let w = item.w;
  let h = item.h;
  if (!item.fixedSize) {
    const natural = getNaturalFrameSize(frame, item);
    w = Math.max(item.w, natural.w);
    h = Math.max(item.h, natural.h);
  }

  const modeKey = getModeKey(config);
  const manual = useManual ? getManual(item.key, modeKey) : null;
  const scale = manual && manual.scale ? manual.scale : (item.scale || 1);
  const finalW = manual && manual.w ? manual.w : w;
  const finalH = manual && manual.h ? manual.h : h;
  const finalX = manual && typeof manual.x === 'number' ? manual.x : item.x;
  const finalY = manual && typeof manual.y === 'number' ? manual.y : item.y;
  const finalZ = manual && manual.z ? manual.z : item.z;

  shell.style.left = finalX + 'px';
  shell.style.top = finalY + 'px';
  shell.style.width = (finalW * scale) + 'px';
  shell.style.height = (finalH * scale) + 'px';
  shell.style.zIndex = finalZ;
  shell.style.setProperty('--win-scale', scale);
  shell.dataset.x = finalX;
  shell.dataset.y = finalY;
  shell.dataset.w = finalW;
  shell.dataset.h = finalH;
  shell.dataset.scale = scale;
  shell.dataset.mode = modeKey;
  shell.dataset.key = item.key;

  frame.style.width = finalW + 'px';
  frame.style.height = finalH + 'px';
  frame.style.transformOrigin = 'top left';
  frame.style.transform = `scale(${scale})`;
  frame.style.zIndex = 1;
}

function applyLayout() {
  const viewportWidth = viewport.clientWidth || window.innerWidth;
  const config = getResponsiveConfig(viewportWidth);
  currentMode = getModeKey(config);

  viewport.style.setProperty('--scene-ratio', `${config.sceneW} / ${config.sceneH}`);
  scene.style.width = config.sceneW + 'px';
  scene.style.height = config.sceneH + 'px';

  if (config.mode === 'mobile') {
    clearManual('mobile');
  }

  for (const item of config.items) {
    updateShellFromItem(item, config, config.mode !== 'mobile');
  }

  scaleScene(config.sceneW, config.sceneH);
}

function bringToFront(key) {
  const shell = shellMap[key];
  if (!shell) return;
  activeZ += 1;
  shell.style.zIndex = activeZ;
  const modeKey = shell.dataset.mode || currentMode;
  setManual(key, modeKey, { z: activeZ });
  Object.values(shellMap).forEach(s => s.classList.remove('is-active'));
  shell.classList.add('is-active');
}
window.__desktopBringToFront = bringToFront;

function clampWindow(x, y, w, h, scale) {
  const sceneW = parseFloat(scene.style.width) || 1265;
  const sceneH = parseFloat(scene.style.height) || 482;
  const scaledW = w * scale;
  const scaledH = h * scale;
  const maxX = Math.max(0, sceneW - scaledW);
  const maxY = Math.max(0, sceneH - scaledH);
  return {
    x: Math.min(Math.max(0, x), maxX),
    y: Math.min(Math.max(0, y), maxY)
  };
}

function startDrag(event, key) {
  if (currentMode === 'mobile') return;
  const shell = shellMap[key];
  if (!shell) return;
  bringToFront(key);
  const startX = event.clientX;
  const startY = event.clientY;
  const origX = parseFloat(shell.dataset.x) || 0;
  const origY = parseFloat(shell.dataset.y) || 0;
  const w = parseFloat(shell.dataset.w) || 100;
  const h = parseFloat(shell.dataset.h) || 100;
  const scale = parseFloat(shell.dataset.scale) || 1;
  shell.classList.add('is-dragging');
  activePointer = {
    type: 'drag', key, shell, startX, startY, origX, origY, w, h, scale,
    move(e) {
      const dx = e.clientX - startX;
      const dy = e.clientY - startY;
      const clamped = clampWindow(origX + dx, origY + dy, w, h, scale);
      shell.style.left = clamped.x + 'px';
      shell.style.top = clamped.y + 'px';
      shell.dataset.x = clamped.x;
      shell.dataset.y = clamped.y;
    },
    end() {
      shell.classList.remove('is-dragging');
      setManual(key, shell.dataset.mode || currentMode, {
        x: parseFloat(shell.dataset.x) || 0,
        y: parseFloat(shell.dataset.y) || 0,
        w, h, scale,
        z: parseInt(shell.style.zIndex || activeZ, 10)
      });
    }
  };
}

function startResize(event, key) {
  if (currentMode !== 'desktop') return;
  const shell = shellMap[key];
  if (!shell) return;
  bringToFront(key);
  const startX = event.clientX;
  const startY = event.clientY;
  const origW = parseFloat(shell.dataset.w) || 100;
  const origH = parseFloat(shell.dataset.h) || 100;
  const origX = parseFloat(shell.dataset.x) || 0;
  const origY = parseFloat(shell.dataset.y) || 0;
  const scale = parseFloat(shell.dataset.scale) || 1;
  const minW = Math.max(180, Math.round(origW * 0.7));
  const minH = Math.max(140, Math.round(origH * 0.7));
  shell.classList.add('is-resizing');
  activePointer = {
    type: 'resize', key, shell,
    move(e) {
      const sceneW = parseFloat(scene.style.width) || 1265;
      const sceneH = parseFloat(scene.style.height) || 482;
      const maxW = Math.max(minW, Math.floor((sceneW - origX) / scale));
      const maxH = Math.max(minH, Math.floor((sceneH - origY) / scale));
      const newW = Math.min(maxW, Math.max(minW, origW + (e.clientX - startX) / scale));
      const newH = Math.min(maxH, Math.max(minH, origH + (e.clientY - startY) / scale));
      shell.dataset.w = newW;
      shell.dataset.h = newH;
      shell.style.width = (newW * scale) + 'px';
      shell.style.height = (newH * scale) + 'px';
      const frame = frameMap[key];
      if (frame) {
        frame.style.width = newW + 'px';
        frame.style.height = newH + 'px';
      }
    },
    end() {
      shell.classList.remove('is-resizing');
      setManual(key, shell.dataset.mode || currentMode, {
        x: parseFloat(shell.dataset.x) || 0,
        y: parseFloat(shell.dataset.y) || 0,
        w: parseFloat(shell.dataset.w) || origW,
        h: parseFloat(shell.dataset.h) || origH,
        scale,
        z: parseInt(shell.style.zIndex || activeZ, 10)
      });
    }
  };
}

document.addEventListener('pointermove', (event) => {
  if (!activePointer) return;
  activePointer.move(event);
});

document.addEventListener('pointerup', () => {
  if (!activePointer) return;
  activePointer.end();
  activePointer = null;
});

document.addEventListener('pointercancel', () => {
  if (!activePointer) return;
  activePointer.end();
  activePointer = null;
});

for (const item of Object.values(BASE_LAYOUT)) {
  const shell = document.createElement('div');
  shell.className = 'desktop-window';
  shell.dataset.key = item.key;

  const frame = document.createElement('iframe');
  frame.className = 'desktop-frame ' + (item.cls || '');
  frame.srcdoc = patchDoc(decodeUtf8Base64(DOCS64[item.key]), item.key);
  frame.setAttribute('scrolling', 'no');
  frame.setAttribute('loading', 'eager');
  frame.style.overflow = 'hidden';

  const dragHandle = document.createElement('div');
  dragHandle.className = 'window-drag-handle';
  dragHandle.title = 'Arrastra la ventana';
  dragHandle.addEventListener('pointerdown', (event) => {
    event.preventDefault();
    startDrag(event, item.key);
  });

  const resizeHandle = document.createElement('div');
  resizeHandle.className = 'window-resize-handle';
  resizeHandle.title = 'Redimensiona la ventana';
  resizeHandle.addEventListener('pointerdown', (event) => {
    event.preventDefault();
    startResize(event, item.key);
  });

  shell.addEventListener('pointerdown', () => bringToFront(item.key));
  frame.addEventListener('load', () => {
    setTimeout(applyLayout, 30);
    setTimeout(applyLayout, 180);
    setTimeout(applyLayout, 600);
  });

  shell.appendChild(frame);
  shell.appendChild(dragHandle);
  shell.appendChild(resizeHandle);
  scene.appendChild(shell);

  frameMap[item.key] = frame;
  shellMap[item.key] = shell;
}

const resizeObserver = new ResizeObserver(() => applyLayout());
resizeObserver.observe(viewport);
window.addEventListener('resize', applyLayout);
window.addEventListener('orientationchange', applyLayout);
window.addEventListener('load', () => {
  setTimeout(applyLayout, 50);
  setTimeout(applyLayout, 250);
  setTimeout(applyLayout, 900);
});
</script>
</body>
</html>
